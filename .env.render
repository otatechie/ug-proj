# Render.com production environment variables
# Copy these into Render dashboard → Environment tab
# DO NOT commit this file with real secrets.

APP_NAME="AI Cybersecurity"
APP_ENV=production
# Generate once with: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://ug-proj.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# No database — stateless app
DB_CONNECTION=sqlite
DB_DATABASE=/tmp/database.sqlite

# Sessions live in encrypted cookies (no DB needed)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

ANALYZE_THROTTLE_ATTEMPTS=10
